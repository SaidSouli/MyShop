{# templates/account/_order_row.html.twig #}
<a href="{{ path('app_account_order_detail',
                {reference: order.reference}) }}"
   class="block border border-gray-100 rounded-xl p-4
          hover:border-indigo-200 hover:shadow-sm
          transition-all">

    <div class="flex items-center justify-between gap-4">

        {# Reference + date #}
        <div>
            <p class="text-sm font-semibold text-gray-900">
                {{ order.reference }}
            </p>
            <p class="text-xs text-gray-400 mt-0.5">
                {{ order.createdAt|date('d M Y') }}
            </p>
        </div>

        {# Status badge #}
        <span class="shrink-0 text-xs font-medium px-2.5 py-1
                     rounded-full
                     {% if order.status.value == 'paid' %}
                         bg-green-100 text-green-700
                     {% elseif order.status.value == 'pending' %}
                         bg-amber-100 text-amber-700
                     {% elseif order.status.value == 'shipped' %}
                         bg-blue-100 text-blue-700
                     {% elseif order.status.value == 'delivered' %}
                         bg-teal-100 text-teal-700
                     {% elseif order.status.value == 'cancelled'
                               or order.status.value == 'refunded' %}
                         bg-red-100 text-red-700
                     {% else %}
                         bg-gray-100 text-gray-600
                     {% endif %}">
            {{ order.status.value|capitalize }}
        </span>

        {# Item count + total #}
        <div class="text-right shrink-0">
            <p class="text-sm font-bold text-gray-900">
                ${{ order.total|number_format(2) }}
            </p>
            <p class="text-xs text-gray-400 mt-0.5">
                {{ order.orderItems|length }} item{{
                    order.orderItems|length != 1 ? 's' : ''
                }}
            </p>
        </div>

    </div>

</a>