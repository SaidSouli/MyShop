{# templates/account/orders.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}My orders — MyShop{% endblock %}

{% block body %}

<div class="max-w-3xl mx-auto">

    {# Breadcrumb #}
    <nav class="text-sm text-gray-500 mb-6 flex items-center gap-2">
        <a href="{{ path('app_account_index') }}"
           class="hover:text-indigo-600">My account</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Orders</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 mb-6">
        Order history
    </h1>

    {% if orders is empty %}
        <div class="bg-white rounded-xl border border-gray-100
                    shadow-sm p-12 text-center text-gray-400">
            <p class="text-base font-medium mb-2">
                No orders yet
            </p>
            <p class="text-sm mb-6">
                When you place an order it will appear here.
            </p>
            <a href="{{ path('app_shop_index') }}"
               class="bg-indigo-600 text-white px-5 py-2.5
                      rounded-lg text-sm font-medium
                      hover:bg-indigo-700 transition-colors">
                Browse products
            </a>
        </div>
    {% else %}
        <div class="space-y-3">
            {% for order in orders %}
                {% include 'account/_order_row.html.twig'
                   with {order: order} %}
            {% endfor %}
        </div>
    {% endif %}

</div>

{% endblock %}