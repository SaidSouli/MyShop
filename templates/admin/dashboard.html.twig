{# templates/admin/dashboard.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block main %}
<div class="row">

    {# Orders by status #}
    <div class="col-12 mb-4">
        <h2 class="h5 mb-3">Orders overview</h2>
        <div class="row g-3">

            <div class="col-sm-6 col-xl-3">
                <div class="card border-warning">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Pending</p>
                        <p class="h4 mb-0 text-warning">
                            {{ pending_count ?? '—' }}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-xl-3">
                <div class="card border-success">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Paid</p>
                        <p class="h4 mb-0 text-success">
                            {{ paid_count ?? '—' }}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-xl-3">
                <div class="card border-info">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Shipped</p>
                        <p class="h4 mb-0 text-info">
                            {{ shipped_count ?? '—' }}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-xl-3">
                <div class="card border-primary">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Delivered</p>
                        <p class="h4 mb-0 text-primary">
                            {{ delivered_count ?? '—' }}
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>

    {# Quick links #}
    <div class="col-12">
        <h2 class="h5 mb-3">Quick actions</h2>
        <div class="d-flex gap-2 flex-wrap">
            <a href="{{ ea_url().setController(
                'App\\Controller\\Admin\\OrderCrudController'
            ).setAction('index').generateUrl() }}"
               class="btn btn-outline-primary btn-sm">
                View all orders
            </a>
            <a href="{{ ea_url().setController(
                'App\\Controller\\Admin\\ProductCrudController'
            ).setAction('new').generateUrl() }}"
               class="btn btn-outline-success btn-sm">
                Add new product
            </a>
        </div>
    </div>

</div>
{% endblock %}