{# templates/cart/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Your Cart — MyShop{% endblock %}

{% block body %}

{% if items is empty %}

    {# ── Empty cart state ── #}
    <div class="flex flex-col items-center justify-center
                py-24 text-center">
        <svg xmlns="http://www.w3.org/2000/svg"
             class="h-16 w-16 text-gray-300 mb-6"
             fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round"
                  stroke-width="1"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4
                     5M7 13l-2 5h12M9 21a1 1 0 100-2 1 1 0
                     000 2zm10 0a1 1 0 100-2 1 1 0 000 2z"/>
        </svg>
        <h1 class="text-2xl font-bold text-gray-900 mb-2">
            Your cart is empty
        </h1>
        <p class="text-gray-500 mb-8">
            Looks like you haven't added anything yet.
        </p>
        <a href="{{ path('app_shop_index') }}"
           class="bg-indigo-600 text-white px-6 py-3 rounded-xl
                  font-medium hover:bg-indigo-700 transition-colors">
            Browse products
        </a>
    </div>

{% else %}

    <h1 class="text-2xl font-bold text-gray-900 mb-8">Your cart</h1>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        {# ── Left column: line items ── #}
        <div class="lg:col-span-2 space-y-4">

            {% for item in items %}
            <div class="bg-white rounded-xl border border-gray-100
                        shadow-sm p-4 flex gap-4">

                {# Product image #}
                <a href="{{ path('app_product_show',
                                {slug: item.product.slug}) }}"
                   class="shrink-0">
                    {% if item.product.imageFilename %}
                        <img
                            src="{{ asset('uploads/products/'
                                   ~ item.product.imageFilename) }}"
                            alt="{{ item.product.name }}"
                            class="w-24 h-24 object-cover rounded-lg">
                    {% else %}
                        <div class="w-24 h-24 bg-gray-100 rounded-lg
                                    flex items-center justify-center
                                    text-gray-300 text-xs">
                            No image
                        </div>
                    {% endif %}
                </a>

                {# Product info #}
                <div class="flex-1 min-w-0">
                    <div class="flex justify-between gap-4">

                        {# Name + category #}
                        <div>
                            {% if item.product.category %}
                                <p class="text-xs text-indigo-600
                                          font-medium uppercase
                                          tracking-wide mb-0.5">
                                    {{ item.product.category.name }}
                                </p>
                            {% endif %}
                            <h2 class="text-sm font-semibold
                                       text-gray-900 leading-snug">
                                <a href="{{ path('app_product_show',
                                               {slug: item.product.slug}) }}"
                                   class="hover:text-indigo-600">
                                    {{ item.product.name }}
                                </a>
                            </h2>
                            <p class="text-sm text-gray-500 mt-0.5">
                                ${{ item.product.price|number_format(2) }}
                                each
                            </p>
                        </div>

                        {# Subtotal #}
                        <div class="text-right shrink-0">
                            <p class="text-base font-bold text-gray-900">
                                ${{ item.subtotal|number_format(2) }}
                            </p>
                        </div>
                    </div>

                    {# Quantity + remove row #}
                    <div class="mt-3 flex items-center gap-4">

                        {# Quantity update form #}
                        <form method="POST"
                              action="{{ path('app_cart_update',
                                            {id: item.product.id}) }}"
                              class="flex items-center gap-2">
                            <input type="hidden"
                                   name="_token"
                                   value="{{ csrf_token(
                                       'update-cart-'
                                       ~ item.product.id
                                   ) }}">
                            <label for="qty_{{ item.product.id }}"
                                   class="text-xs text-gray-500">
                                Qty
                            </label>
                            <input
                                type="number"
                                id="qty_{{ item.product.id }}"
                                name="quantity"
                                value="{{ item.quantity }}"
                                min="1"
                                max="{{ item.product.stock }}"
                                class="w-16 border border-gray-300
                                       rounded-lg px-2 py-1 text-sm
                                       text-center focus:outline-none
                                       focus:ring-2 focus:ring-indigo-400"
                                onchange="this.form.submit()">
                        </form>

                        {# Remove form #}
                        <form method="POST"
                              action="{{ path('app_cart_remove',
                                            {id: item.product.id}) }}">
                            <input type="hidden"
                                   name="_token"
                                   value="{{ csrf_token(
                                       'remove-from-cart-'
                                       ~ item.product.id
                                   ) }}">
                            <button type="submit"
                                    class="text-xs text-red-500
                                           hover:text-red-700
                                           hover:underline">
                                Remove
                            </button>
                        </form>
                    </div>
                </div>

            </div>
            {% endfor %}

            {# Clear cart form #}
            <div class="flex justify-end pt-2">
                <form method="POST"
                      action="{{ path('app_cart_clear') }}">
                    <input type="hidden"
                           name="_token"
                           value="{{ csrf_token('clear-cart') }}">
                    <button type="submit"
                            class="text-sm text-gray-400
                                   hover:text-red-500 hover:underline"
                            onclick="return confirm(
                                'Clear your entire cart?'
                            )">
                        Clear cart
                    </button>
                </form>
            </div>

        </div>

        {# ── Right column: order summary ── #}
        <div class="lg:col-span-1">
            <div class="bg-white rounded-xl border border-gray-100
                        shadow-sm p-6 sticky top-24">

                <h2 class="text-lg font-bold text-gray-900 mb-4">
                    Order summary
                </h2>

                {# Line breakdown #}
                <div class="space-y-2 text-sm text-gray-600 mb-4">
                    {% for item in items %}
                        <div class="flex justify-between">
                            <span class="truncate pr-4">
                                {{ item.product.name }}
                                <span class="text-gray-400">
                                    × {{ item.quantity }}
                                </span>
                            </span>
                            <span class="shrink-0 font-medium
                                         text-gray-900">
                                ${{ item.subtotal|number_format(2) }}
                            </span>
                        </div>
                    {% endfor %}
                </div>

                <hr class="border-gray-200 my-4">

                {# Subtotal #}
                <div class="flex justify-between text-sm
                            text-gray-600 mb-2">
                    <span>Subtotal</span>
                    <span class="font-medium text-gray-900">
                        ${{ total|number_format(2) }}
                    </span>
                </div>

                {# Shipping placeholder #}
                <div class="flex justify-between text-sm
                            text-gray-600 mb-4">
                    <span>Shipping</span>
                    <span class="text-gray-400 italic">
                        Calculated at checkout
                    </span>
                </div>

                <hr class="border-gray-200 mb-4">

                {# Total #}
                <div class="flex justify-between text-base
                            font-bold text-gray-900 mb-6">
                    <span>Total</span>
                    <span>${{ total|number_format(2) }}</span>
                </div>

                {# Checkout button #}
                <a href="{{ path('app_checkout_index') }}"
                   class="block w-full text-center bg-indigo-600
                          text-white font-medium py-3 rounded-xl
                          hover:bg-indigo-700 transition-colors">
                    Proceed to checkout
                </a>

                {# Continue shopping link #}
                <a href="{{ path('app_shop_index') }}"
                   class="block w-full text-center text-sm
                          text-gray-500 hover:text-indigo-600
                          mt-3">
                    ← Continue shopping
                </a>

            </div>
        </div>

    </div>

{% endif %}

{% endblock %}
