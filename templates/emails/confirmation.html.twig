{# templates/emails/order_confirmation.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: sans-serif; color: #374151;
               line-height: 1.6; margin: 0; padding: 0; }
        .container { max-width: 560px; margin: 0 auto; padding: 32px 24px; }
        .header { text-align: center; margin-bottom: 32px; }
        .ref { background: #eef2ff; border-radius: 12px;
               padding: 16px 24px; text-align: center;
               margin-bottom: 24px; }
        .ref p { margin: 0; }
        .ref .label { font-size: 11px; color: #6366f1;
                      text-transform: uppercase; letter-spacing: 0.05em; }
        .ref .value { font-size: 22px; font-weight: 700;
                      color: #4338ca; letter-spacing: 0.1em; }
        table { width: 100%; border-collapse: collapse;
                font-size: 14px; }
        td { padding: 8px 0; border-bottom: 1px solid #f3f4f6; }
        .total-row td { border-bottom: none; font-weight: 700;
                        font-size: 16px; padding-top: 16px; }
        .footer { margin-top: 32px; text-align: center;
                  font-size: 12px; color: #9ca3af; }
    </style>
</head>
<body>
<div class="container">

    <div class="header">
        <h1 style="color:#4f46e5;margin:0 0 8px">MyShop</h1>
        <p style="margin:0;color:#6b7280">
            Thanks for your order, {{ order.user.firstName }}!
        </p>
    </div>

    <div class="ref">
        <p class="label">Order reference</p>
        <p class="value">{{ order.reference }}</p>
    </div>

    <table>
        <thead>
            <tr>
                <td style="font-weight:600;color:#6b7280;
                           font-size:12px;text-transform:uppercase">
                    Product
                </td>
                <td style="text-align:center;font-weight:600;
                           color:#6b7280;font-size:12px;
                           text-transform:uppercase">
                    Qty
                </td>
                <td style="text-align:right;font-weight:600;
                           color:#6b7280;font-size:12px;
                           text-transform:uppercase">
                    Price
                </td>
            </tr>
        </thead>
        <tbody>
            {% for item in order.items %}
            <tr>
                <td>{{ item.getProductName() }}</td>
                <td style="text-align:center">{{ item.quantity }}</td>
                <td style="text-align:right">
                    ${{ item.getSubtotal()|number_format(2) }}
                </td>
            </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr class="total-row">
                <td colspan="2">Total</td>
                <td style="text-align:right">
                    ${{ order.total|number_format(2) }}
                </td>
            </tr>
        </tfoot>
    </table>

    <div style="margin-top:24px;padding:16px;background:#f9fafb;
                border-radius:10px;font-size:14px;">
        <p style="margin:0 0 4px;font-weight:600">Shipping to</p>
        <p style="margin:0;color:#6b7280">
            {{ order.shippingAddress }},
            {{ order.shippingCity }},
            {{ order.shippingPostcode }},
            {{ order.shippingCountry }}
        </p>
    </div>

    <div class="footer">
        <p>MyShop · If you have questions reply to this email.</p>
    </div>

</div>
</body>
</html>