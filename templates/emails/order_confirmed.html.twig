{# templates/emails/order_confirmation.html.twig #}
<h1>Thank you for your order!</h1>

<p>We've successfully processed your payment for order <strong>#{{ order.id }}</strong>.</p>

<table style="width: 100%; border-collapse: collapse;">
    <thead>
        <tr style="background-color: #f8f9fa;">
            <th style="text-align: left; padding: 10px; border: 1px solid #dee2e6;">Product</th>
            <th style="text-align: center; padding: 10px; border: 1px solid #dee2e6;">Quantity</th>
            <th style="text-align: right; padding: 10px; border: 1px solid #dee2e6;">Price</th>
        </tr>
    </thead>
    <tbody>
        {% for item in order.orderItems %}
            <tr>
                <td style="padding: 10px; border: 1px solid #dee2e6;">{{ item.product.name }}</td>
                <td style="text-align: center; padding: 10px; border: 1px solid #dee2e6;">{{ item.quantity }}</td>
                <td style="text-align: right; padding: 10px; border: 1px solid #dee2e6;">{{ (item.price * item.quantity)|number_format(2) }} USD</td>
            </tr>
        {% endfor %}
    </tbody>
    <tfoot>
        <tr>
            <td colspan="2" style="text-align: right; padding: 10px; font-weight: bold;">Total Paid:</td>
            <td style="text-align: right; padding: 10px; font-weight: bold; color: #28a745;">{{ order.total|number_format(2) }} USD</td>
        </tr>
    </tfoot>
</table>

<p>You can view your full order history by logging into your account at MyShop.</p>

<p>Best regards,<br>The MyShop Team</p>