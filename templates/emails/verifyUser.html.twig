{# templates/emails/confirmation.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: system-ui, sans-serif; background: #f8fafc; margin: 0; padding: 40px 20px; }
        .card { max-width: 480px; margin: 0 auto; background: #fff; border-radius: 12px; border: 1px solid #e2e8f0; padding: 40px; }
        .logo { display: flex; align-items: center; gap: 8px; margin-bottom: 32px; }
        .logo-icon { width: 32px; height: 32px; background: #2563eb; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
        h1 { font-size: 20px; font-weight: 600; color: #1e293b; margin: 0 0 8px; }
        p { font-size: 14px; color: #64748b; line-height: 1.6; margin: 0 0 24px; }
        .btn { display: inline-block; background: #2563eb; color: #fff; text-decoration: none; padding: 12px 28px; border-radius: 10px; font-size: 14px; font-weight: 600; }
        .footer { margin-top: 32px; padding-top: 24px; border-top: 1px solid #f1f5f9; font-size: 12px; color: #94a3b8; }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo">
            <div class="logo-icon">
                <img src="https://via.placeholder.com/18x18/ffffff/ffffff?text=+" width="18" height="18" alt="">
            </div>
            <strong style="font-size:17px; color:#1e293b;">My<span style="color:#2563eb">Shop</span></strong>
        </div>

        <h1>Confirm your email address</h1>
        <p>Hi {{ user.firstName }}, thanks for signing up! Click the button below to verify your email and activate your account.</p>

        <a href="{{ signedUrl }}" class="btn">Verify my email</a>

        <p style="margin-top: 24px; font-size: 13px;">
            This link expires in <strong>1 hour</strong>. If you didn't create an account, you can safely ignore this email.
        </p>

        <div class="footer">
            © {{ "now"|date("Y") }} MyShop · If the button doesn't work, copy this link:<br>
            <a href="{{ signedUrl }}" style="color:#2563eb; word-break:break-all;">{{ signedUrl }}</a>
        </div>
    </div>
</body>
</html>