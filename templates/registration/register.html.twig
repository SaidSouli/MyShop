{# templates/registration/register.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Create account — MyShop{% endblock %}

{% block body %}

<div class="min-h-[70vh] flex items-center justify-center py-12">
    <div class="w-full max-w-md">

        {# Header #}
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900">
                Create account
            </h1>
            <p class="text-gray-500 mt-2 text-sm">
                Already have an account?
                <a href="{{ path('app_login') }}"
                   class="text-indigo-600 hover:underline font-medium">
                    Sign in
                </a>
            </p>
        </div>

        {# Form card #}
        <div class="bg-white rounded-2xl shadow-sm border
                    border-gray-100 p-8">

            {{ form_start(form) }}

                {# First + Last name row #}
                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div>
                        {{ form_label(form.firstName, null, {
                            'label_attr': {
                                'class': 'block text-sm font-medium
                                          text-gray-700 mb-1'
                            }
                        }) }}
                        {{ form_widget(form.firstName) }}
                        <div class="mt-1 text-xs text-red-600">
                            {{ form_errors(form.firstName) }}
                        </div>
                    </div>
                    <div>
                        {{ form_label(form.lastName, null, {
                            'label_attr': {
                                'class': 'block text-sm font-medium
                                          text-gray-700 mb-1'
                            }
                        }) }}
                        {{ form_widget(form.lastName) }}
                        <div class="mt-1 text-xs text-red-600">
                            {{ form_errors(form.lastName) }}
                        </div>
                    </div>
                </div>

                {# Email #}
                <div class="mb-4">
                    {{ form_label(form.email, null, {
                        'label_attr': {
                            'class': 'block text-sm font-medium
                                      text-gray-700 mb-1'
                        }
                    }) }}
                    {{ form_widget(form.email) }}
                    <div class="mt-1 text-xs text-red-600">
                        {{ form_errors(form.email) }}
                    </div>
                </div>

                {# Password #}
                <div class="mb-4">
                    {{ form_label(form.plainPassword.first, null, {
                        'label_attr': {
                            'class': 'block text-sm font-medium
                                      text-gray-700 mb-1'
                        }
                    }) }}
                    {{ form_widget(form.plainPassword.first) }}
                    <div class="mt-1 text-xs text-red-600">
                        {{ form_errors(form.plainPassword.first) }}
                    </div>
                </div>

                {# Confirm password #}
                <div class="mb-4">
                    {{ form_label(form.plainPassword.second, null, {
                        'label_attr': {
                            'class': 'block text-sm font-medium
                                      text-gray-700 mb-1'
                        }
                    }) }}
                    {{ form_widget(form.plainPassword.second) }}
                    <div class="mt-1 text-xs text-red-600">
                        {{ form_errors(form.plainPassword.second) }}
                    </div>
                    {# This is where "passwords don't match" appears #}
                    <div class="mt-1 text-xs text-red-600">
                        {{ form_errors(form.plainPassword) }}
                    </div>
                </div>

                {# Terms checkbox #}
                <div class="mb-6 flex items-start gap-3">
                    {{ form_widget(form.agreeTerms) }}
                    {{ form_label(form.agreeTerms, null, {
                        'label_attr': {
                            'class': 'text-sm text-gray-600 leading-snug'
                        }
                    }) }}
                </div>
                <div class="mb-4 text-xs text-red-600">
                    {{ form_errors(form.agreeTerms) }}
                </div>

                {# Submit #}
                <button type="submit"
                        class="w-full bg-indigo-600 text-white
                               font-medium py-3 rounded-xl
                               hover:bg-indigo-700 transition-colors">
                    Create account
                </button>

            {{ form_end(form) }}

        </div>

        {# Footer note #}
        <p class="text-center text-xs text-gray-400 mt-6">
            By registering you agree to our
            <a href="#" class="underline hover:text-gray-600">
                Terms of Service
            </a>
            and
            <a href="#" class="underline hover:text-gray-600">
                Privacy Policy
            </a>.
        </p>

    </div>
</div>

{% endblock %}