{# templates/security/login.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Sign in — MyShop{% endblock %}

{% block body %}

<div class="min-h-[70vh] flex items-center justify-center py-12">
    <div class="w-full max-w-md">

        {# Header #}
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900">
                Welcome back
            </h1>
            <p class="text-gray-500 mt-2 text-sm">
                Don't have an account?
                <a href="{{ path('app_register') }}"
                   class="text-indigo-600 hover:underline font-medium">
                    Create one
                </a>
            </p>
        </div>

        {# Form card #}
        <div class="bg-white rounded-2xl shadow-sm border
                    border-gray-100 p-8">

            {# Authentication error — wrong password etc #}
            {% if error %}
                <div class="mb-4 px-4 py-3 bg-red-50 border
                            border-red-200 rounded-lg text-sm
                            text-red-700">
                    {{ error.messageKey|trans(
                        error.messageData, 'security'
                    ) }}
                </div>
            {% endif %}

            <form method="POST" action="{{ path('app_login') }}">

                {# CSRF token — required, matches 'authenticate'
                   in AppAuthenticator::authenticate() #}
                <input type="hidden"
                       name="_csrf_token"
                       value="{{ csrf_token('authenticate') }}">

                {# Email #}
                <div class="mb-4">
                    <label for="inputEmail"
                           class="block text-sm font-medium
                                  text-gray-700 mb-1">
                        Email address
                    </label>
                    <input type="email"
                           id="inputEmail"
                           name="email"
                           value="{{ last_username }}"
                           required
                           autofocus
                           autocomplete="email"
                           class="w-full border border-gray-300
                                  rounded-lg px-4 py-2 text-sm
                                  focus:outline-none focus:ring-2
                                  focus:ring-indigo-400">
                </div>

                {# Password #}
                <div class="mb-4">
                    <div class="flex justify-between items-center mb-1">
                        <label for="inputPassword"
                               class="block text-sm font-medium
                                      text-gray-700">
                            Password
                        </label>
                        {# Placeholder — wire up in Phase 5 #}
                        <a href="#"
                           class="text-xs text-indigo-600
                                  hover:underline">
                            Forgot password?
                        </a>
                    </div>
                    <input type="password"
                           id="inputPassword"
                           name="password"
                           required
                           autocomplete="current-password"
                           class="w-full border border-gray-300
                                  rounded-lg px-4 py-2 text-sm
                                  focus:outline-none focus:ring-2
                                  focus:ring-indigo-400">
                </div>

                {# Remember me #}
                <div class="mb-6 flex items-center gap-2">
                    <input type="checkbox"
                           id="remember_me"
                           name="_remember_me"
                           class="rounded border-gray-300
                                  text-indigo-600
                                  focus:ring-indigo-400">
                    <label for="remember_me"
                           class="text-sm text-gray-600">
                        Remember me for 7 days
                    </label>
                </div>

                {# Submit #}
                <button type="submit"
                        class="w-full bg-indigo-600 text-white
                               font-medium py-3 rounded-xl
                               hover:bg-indigo-700
                               transition-colors">
                    Sign in
                </button>

            </form>

        </div>

        {# Footer note #}
        <p class="text-center text-xs text-gray-400 mt-6">
            Protected by CSRF token and secure password hashing.
        </p>

    </div>
</div>

{% endblock %}